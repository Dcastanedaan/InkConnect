<h1 class="mb-4">Todos los Portfolios</h1>

<div class="container">
  <div class="row g-4">
    <% @portfolios.each do |portfolio| %>
      <div class="col-md-6 col-lg-4 d-flex"> <!-- flex para altura uniforme -->
        <div class="card shadow-sm portfolio-card d-flex flex-column w-100">
          <div class="card-body d-flex flex-column flex-grow-1">

            <!-- Título y enlace -->
            <h3 class="card-title">
              <%= link_to portfolio.title, tattoo_artist_portfolio_path(portfolio.tattoo_artist, portfolio), class: "text-decoration-none" %>
            </h3>

            <!-- Artista -->
            <p class="text-muted mb-2">Artista: <%= portfolio.tattoo_artist.user.name %></p>

            <!-- Descripción -->
            <p class="card-text flex-shrink-0"><%= portfolio.description %></p>

            <!-- Imágenes -->
            <% if portfolio.images.attached? %>
              <% images_count = portfolio.images.count %>
              <% grid_class = case images_count
                  when 1 then "one"
                  when 2 then "two"
                  when 3 then "three"
                  when 4 then "four"
                  else "more"
                end %>

              <div class="portfolio-images <%= grid_class %> flex-grow-1 mb-3">
                <% portfolio.images.each do |img| %>
                  <%= image_tag img.variant(resize_to_limit: [300, 300]).processed, alt: portfolio.title %>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted flex-grow-1">No hay imágenes</p>
            <% end %>

            <!-- Like -->
            <div class="like-container mt-auto">
              <div class="me-3" id="like_frame_<%= portfolio.id %>">
                <% like = portfolio.likes.find_by(user: current_user) %>

                <% if like %>
                  <%= button_to tattoo_artist_portfolio_like_path(portfolio.tattoo_artist, portfolio, like),
                      method: :delete,
                      form: { data: { turbo_stream: true } },
                      class: "like-btn" do %>
                    <i class="fa-solid fa-heart text-danger"></i>
                  <% end %>
                <% else %>
                  <%= button_to tattoo_artist_portfolio_likes_path(portfolio.tattoo_artist, portfolio),
                      method: :post,
                      form: { data: { turbo_stream: true } },
                      class: "like-btn" do %>
                    <i class="fa-regular fa-heart"></i>
                  <% end %>
                <% end %>
              </div>

              <span id="like_count_<%= portfolio.id %>" class="fw-bold">
                Likes: <%= portfolio.likes.count %>
              </span>
            </div>

          </div> <!-- card-body -->
        </div> <!-- card -->
      </div> <!-- col -->
    <% end %>
  </div>
</div>
