<h1 class="mb-4">Todos los Portfolios</h1>

<div class="container">
  <div class="row g-4">
    <% @portfolios.each do |portfolio| %>
      <div class="col-12">
        <div class="card shadow-sm">
          <div class="card-body">
            <!-- Título y enlace -->
            <h3 class="card-title">
              <%= link_to portfolio.title, tattoo_artist_portfolio_path(portfolio.tattoo_artist, portfolio), class: "text-decoration-none" %>
            </h3>

            <!-- Artista -->
            <p class="text-muted mb-2">Artista: <%= portfolio.tattoo_artist.user.name %></p>

            <!-- Descripción -->
            <p class="card-text"><%= portfolio.description %></p>

            <!-- Imágenes -->
            <% if portfolio.images.attached? %>
              <div class="d-flex flex-wrap gap-2 mb-3">
                <% portfolio.images.each do |img| %>
                  <div class="card" style="width: 150px;">
                    <%= image_tag img.variant(resize_to_limit: [300, 300]).processed, class: "card-img-top", style: "height: 150px; object-fit: cover;", alt: portfolio.title %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted">No hay imágenes</p>
            <% end %>

            <!-- Botón Like y contador -->
            <div class="d-flex align-items-center">
              <div class="me-3" id="like_frame_<%= portfolio.id %>">
                <% like = portfolio.likes.find_by(user: current_user) %>
                <% if like %>
                  <%= button_to "Unlike",
                      tattoo_artist_portfolio_like_path(portfolio.tattoo_artist, portfolio, like),
                      method: :delete,
                      form: { data: { turbo_stream: true } },
                      class: "btn btn-outline-danger btn-sm" %>
                <% else %>
                  <%= button_to "Like",
                      tattoo_artist_portfolio_likes_path(portfolio.tattoo_artist, portfolio),
                      method: :post,
                      form: { data: { turbo_stream: true } },
                      class: "btn btn-outline-primary btn-sm" %>
                <% end %>
              </div>

              <span id="like_count_<%= portfolio.id %>" class="fw-bold">
                Likes: <%= portfolio.likes.count %>
              </span>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
