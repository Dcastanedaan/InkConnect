<%= turbo_frame_tag "new_portfolio" do %>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card shadow-sm">
          <div class="card-header bg-primary text-white text-center">
            <h2 class="mb-0">Nuevo portfolio</h2>
          </div>
          <div class="card-body">
            <%= form_with model: [@tattoo_artist, @portfolio], local: true, html: { multipart: true } do |f| %>

              <div class="mb-3">
                <%= f.label :title, "Título", class: "form-label" %>
                <%= f.text_field :title, class: "form-control" %>
              </div>

              <div class="mb-3">
                <%= f.label :description, "Descripción", class: "form-label" %>
                <%= f.text_area :description, class: "form-control", rows: 4 %>
              </div>

              <div class="mb-3">
                <%= f.label :images, "Imágenes", class: "form-label" %>
                <%= f.file_field :images, multiple: true, class: "form-control" %>
              </div>

              <div class="text-center">
                <%= f.submit "Crear", class: "btn btn-primary" %>
              </div>

            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
