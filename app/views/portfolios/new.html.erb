<%= turbo_frame_tag "new_portfolio" do %>

  <h2>Nuevo portfolio</h2>

  <%= form_with model: [@tattoo_artist, @portfolio] do |f| %>

    <div>
      <%= f.label :title %>
      <%= f.text_field :title %>
    </div>

    <div>
      <%= f.label :description %>
      <%= f.text_area :description %>
    </div>

    <div>
      <%= f.label :images %>
      <%= f.file_field :images, multiple: true %>
    </div>

    <%= f.submit "Crear" %>

  <% end %>

<% end %>
