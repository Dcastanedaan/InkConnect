<div class="container mt-4">
  <div class="row">

    <!-- Left Column: Portfolio -->
    <div class="col-md-6 mb-3 d-flex">
      <div class="card shadow-sm portfolio-card d-flex flex-column w-100">
        <div class="card-header bg-primary text-white">
          <h2 class="mb-0">Portafolio</h2>
        </div>

        <div class="card-body d-flex flex-column flex-grow-1">

          <!-- Portfolio Information -->
          <div class="mb-2">
            <p class="fw-bold mb-0"><%= @portfolio.tattoo_artist.user.name %></p>
            <div class="d-flex align-items-center fw-bold mb-1">
              <p class="mb-0 me-2"><%= @portfolio.title %></p>
              <span class="badge bg-primary"><%= @portfolio.likes.count %> ❤️</span>
            </div>
            <p class="text-muted mb-2"><%= @portfolio.description %></p>
          </div>

          <!-- Images Container -->
          <% if @portfolio.images.attached? %>
            <% images_count = @portfolio.images.count %>
            <% grid_class = case images_count
                when 1 then "one"
                when 2 then "two"
                when 3 then "three"
                when 4 then "four"
                else "more"
              end %>

            <div class="portfolio-images <%= grid_class %> flex-grow-1 mb-2">
              <% @portfolio.images.each do |img| %>
                <div class="image-card">
                  <%= image_tag img, alt: @portfolio.title %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted flex-grow-1">No images</p>
          <% end %>

          <!-- Like Button at the bottom -->
          <div class="like-container mt-auto">
            <div class="me-3" id="like_frame_<%= @portfolio.id %>">
              <%= turbo_frame_tag "like_frame_#{@portfolio.id}" do %>
                <% like = @portfolio.likes.find_by(user: current_user) %>
                <% if like %>
                  <%= button_to tattoo_artist_portfolio_like_path(@portfolio.tattoo_artist, @portfolio, like),
                      method: :delete,
                      form: { data: { turbo_stream: true } },
                      class: "like-btn" do %>
                    <i class="fa-solid fa-heart"></i>
                  <% end %>
                <% else %>
                  <%= button_to tattoo_artist_portfolio_likes_path(@portfolio.tattoo_artist, @portfolio),
                      method: :post,
                      form: { data: { turbo_stream: true } },
                      class: "like-btn" do %>
                    <i class="fa-regular fa-heart"></i>
                  <% end %>
                <% end %>
              <% end %>
            </div>
            <span id="like_count_<%= @portfolio.id %>" class="fw-bold">
              Likes: <%= @portfolio.likes.count %>
            </span>
          </div>

        </div>
      </div>
    </div>

    <!-- Right Column: Comments -->
    <div class="col-md-6 mb-3 d-flex">
      <div class="card shadow-sm comments-container w-100">

        <!-- Header -->
        <div class="card-header bg-secondary text-white">
          <h3 class="mb-0">Comentaios</h3>
        </div>

        <!-- Body -->
        <div class="card-body d-flex flex-column flex-grow-2">

          <!-- Fixed Form at top -->
          <% if user_signed_in? %>
            <div id="new_comment" class="new-comment-form ">
              <%= render "comments/form", portfolio: @portfolio, comment: @portfolio.comments.build %>
            </div>
          <% else %>
            <p class="text-muted">You must sign in to comment.</p>
          <% end %>

          <!-- Scrollable comment list -->
          <div class="comments-list flex-grow-1 overflow-auto px-1 mt-2" id="comments_list">
            <%= render @portfolio.comments.includes(:user).order(created_at: :desc) %>
          </div>

        </div>
      </div>
    </div>

  </div>
</div>
