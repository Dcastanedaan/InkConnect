<div class="container mt-4">
  <div class="row">
    <!-- Columna izquierda: Portfolio -->
    <div class="col-md-6 mb-3">
      <div class="card shadow-sm" style="height: 500px;">
        <div class="card-header bg-primary text-white">
          <h2 class="mb-0">Portfolio</h2>
        </div>

        <div class="card-body d-flex flex-column" style="height: 100%;">
          <!-- Imágenes -->
          <% if @portfolio.images.attached? %>
            <div class="d-flex flex-wrap gap-2 mb-3 flex-grow-1 overflow-auto">
              <% @portfolio.images.each do |img| %>
                <div class="card" style="width: 180px;">
                  <%= image_tag img, class: "card-img-top", style: "height: 120px; object-fit: cover;" %>

                  <div class="card-body p-1 d-flex justify-content-between align-items-center">
                    <!-- Contador de likes de la imagen -->
                    <span class="badge bg-primary"><%= @portfolio.likes.count %> ❤️</span>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted">No hay imágenes</p>
          <% end %>

          <!-- Botón Like general debajo de todas las imágenes -->
          <div class="mt-2 d-flex align-items-center">
            <%= turbo_frame_tag "like_frame_#{@portfolio.id}" do %>
              <% like = @portfolio.likes.find_by(user: current_user) %>

              <% if like %>
                <%= button_to "Unlike",
                    tattoo_artist_portfolio_like_path(@portfolio.tattoo_artist, @portfolio, like),
                    method: :delete,
                    form: { data: { turbo_stream: true } },
                    class: "btn btn-outline-danger me-2" %>
              <% else %>
                <%= button_to "Like",
                    tattoo_artist_portfolio_likes_path(@portfolio.tattoo_artist, @portfolio),
                    method: :post,
                    form: { data: { turbo_stream: true } },
                    class: "btn btn-outline-primary me-2" %>
              <% end %>
            <% end %>

            <span id="like_count_<%= @portfolio.id %>" class="fw-bold">
              Likes: <%= @portfolio.likes.count %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Columna derecha: Comentarios -->
    <div class="col-md-6 mb-3">
      <div class="card shadow-sm" style="height: 500px;">
        <div class="card-header bg-secondary text-white">
          <h3 class="mb-0">Comentarios</h3>
        </div>

        <div class="card-body d-flex flex-column" style="height: 100%;">
          <!-- Lista de comentarios como tarjetas -->
          <div class="flex-grow-1 overflow-auto mb-3">
            <% @portfolio.comments.includes(:user).each do |comment| %>
              <div class="card mb-2">
                <div class="card-body p-2">
                  <p class="mb-1"><%= comment.body %></p>

                  <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                      <%= comment.user.name %> · <%= time_ago_in_words(comment.created_at) %> ago
                    </small>

                    <% if current_user == comment.user || current_user.admin? %>
                      <%= button_to "Eliminar",
                          tattoo_artist_portfolio_comment_path(@portfolio.tattoo_artist, @portfolio, comment),
                          method: :delete,
                          form: { data: { turbo_stream: true } },
                          class: "btn btn-sm btn-outline-danger" %>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
            <div class="mt-2">
            <div class="flex-row">
              <% if user_signed_in? %>
                <div id="new_comment" class="card p-3">
                  <%= render "comments/form",
                      portfolio: @portfolio,
                      comment: @portfolio.comments.build %>
                  <!-- Solo agregamos Bootstrap para que textarea y botón estén alineados verticalmente -->
                  <style>
                    #new_comment form {
                      display: flex;
                      flex-direction: column;
                    }
                    #new_comment textarea {
                      margin-bottom: 0.5rem;
                    }
                    #new_comment input[type="submit"] {
                      align-self: flex-end;
                    }
                  </style>
                </div>
              <% else %>
                <p class="text-muted">Debes iniciar sesión para comentar.</p>
              <% end %>
            </div>
          </div>
          </div>

          <!-- Formulario para nuevo comentario -->
          
        </div>
      </div>
    </div>
  </div>
</div>
