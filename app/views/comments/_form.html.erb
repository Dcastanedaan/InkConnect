<%= form_with(model: [portfolio.tattoo_artist, portfolio, comment]) do |f| %>
  <% if comment.errors.any? %>
    <div>
      <ul>
        <% comment.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-2">
    <%= f.text_area :body,
        placeholder: "Escribe un comentario...",
        class: "form-control custom-textarea",
        rows: 2 %>
  </div>

  <div class="text-end">
    <%= f.submit "Comenta", class: "btn custom-btn" %>
  </div>
<% end %>
