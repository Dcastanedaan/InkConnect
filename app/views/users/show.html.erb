<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center">
          <h1 class="mb-0"><%= @user.username %></h1>
        </div>
        <div class="card-body">
          <p><strong>Nombre:</strong> <%= @user.name %></p>
          <p><strong>Bio:</strong> <%= @user.bio.presence || "Sin información" %></p>
          <p><strong>Ubicación:</strong> <%= @user.location.presence || "Sin información" %></p>
          <p><strong>Rol:</strong> <%= @user.role %></p>
          <p><strong>Email:</strong> <%= @user.email %></p>
        </div>
        <div class="card-footer text-center">
          <%= link_to "Volver", users_path, class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>
  </div>
</div>
