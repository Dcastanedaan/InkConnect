<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        
        <div class="card-header bg-primary text-white text-center">
          <h2 class="mb-0">Editar <%= resource_name.to_s.humanize %></h2>
        </div>

        <div class="card-body">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
            
            <%= render "devise/shared/error_messages", resource: resource %>

            <!-- 👇 NUEVO CAMPO -->
            <div class="mb-3">
              <%= f.label :name, "Nombre", class: "form-label" %>
              <%= f.text_field :name, class: "form-control" %>
            </div>
            <div class="mb-3">
              <%= f.label :username, "username", class: "form-label" %>
              <%= f.text_field :username, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :email, "Correo electrónico", class: "form-label" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
            </div>

            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="alert alert-warning">
                Esperando confirmación para: <%= resource.unconfirmed_email %>
              </div>
            <% end %>

            <div class="mb-3">
              <%= f.label :password, "Nueva contraseña", class: "form-label" %>
              <small class="text-muted">(déjalo en blanco si no quieres cambiarla)</small>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
              
              <% if @minimum_password_length %>
                <small class="form-text text-muted">
                  Mínimo <%= @minimum_password_length %> caracteres
                </small>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, "Confirmar contraseña", class: "form-label" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :current_password, "Contraseña actual", class: "form-label" %>
              <small class="text-muted">(necesaria para confirmar los cambios)</small>
              <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
            </div>

            <div class="text-center">
              <%= f.submit "Actualizar", class: "btn btn-primary" %>
            </div>

          <% end %>
        </div>

        <div class="card-footer text-center">
          <p class="mb-2">¿No estás satisfecho?</p>

          <%= button_to "Eliminar mi cuenta",
              registration_path(resource_name),
              method: :delete,
              data: { confirm: "¿Estás seguro?", turbo_confirm: "¿Estás seguro?" },
              class: "btn btn-danger mb-2" %>

          <br>

          <%= link_to "Volver", :back, class: "btn btn-outline-primary" %>
        </div>

      </div>
    </div>
  </div>
</div>
